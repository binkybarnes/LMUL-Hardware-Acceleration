# SConscript for LMUL Accelerator

Import('*')

# Guard to ensure we only add sources once per SCons process
# This prevents duplicate object files in the linker command
if 'lmul_accel_sources_added' not in globals():
    # Compile C++ source files
    Source('lmul_accelerator.cc')
    lmul_accel_sources_added = True

# Include Python configuration
# Use a file-based guard to prevent duplicate SimObject registration
# This works even if SConscript is executed in separate Python contexts
import os
guard_file = 'lmul_accel_registered.flag'
if not os.path.exists(guard_file):
    SimObject('LMulAccelerator.py', sim_objects=['LMulAccelerator'])
    # Create guard file to prevent duplicate registration
    open(guard_file, 'w').close()

# Debug flags for this device
try:
    DebugFlag('LMulAccel', "LMUL Accelerator operations")
except AttributeError as e:
    if 'already specified' in str(e):
        pass
    else:
        raise

try:
    DebugFlag('LMulAccelVerbose', "Detailed LMUL Accelerator operations")
except AttributeError as e:
    if 'already specified' in str(e):
        pass
    else:
        raise
