# SConscript for LMUL Accelerator

Import('*')

# Compile C++ source files
Source('lmul_accelerator.cc')

# Include Python configuration
# Use try/except to handle case where SimObject is already registered
# This can happen if SConscript is processed multiple times or bindings exist
try:
    SimObject('LMulAccelerator.py', sim_objects=['LMulAccelerator'])
except Exception as e:
    # Catch any exception related to duplicate registration
    error_msg = str(e).lower()
    if 'already found' in error_msg or 'already registered' in error_msg or 'already exists' in error_msg:
        # SimObject already registered, which is fine - skip registration
        pass
    else:
        # Re-raise if it's a different error
        raise

# Debug flags for this device
# Use try/except to handle case where flag is already registered
# This can happen if SConscript is processed multiple times
try:
    DebugFlag('LMulAccel', "LMUL Accelerator operations")
except AttributeError as e:
    if 'already specified' in str(e):
        # Flag already registered, which is fine
        pass
    else:
        raise

try:
    DebugFlag('LMulAccelVerbose', "Detailed LMUL Accelerator operations")
except AttributeError as e:
    if 'already specified' in str(e):
        # Flag already registered, which is fine
        pass
    else:
        raise
