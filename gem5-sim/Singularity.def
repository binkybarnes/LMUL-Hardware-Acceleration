Bootstrap: docker
From: ubuntu:22.04

%environment
    export DEBIAN_FRONTEND=noninteractive
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    # Ensure pip-installed console scripts (e.g., jupyter) are on PATH
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH

%post
    # Update package lists and install system dependencies
    apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        make \
        git \
        wget \
        curl \
        ca-certificates \
        gzip \
        m4 \
        scons \
        pkg-config \
        python3 \
        python3-pip \
        python3-dev \
        python3-venv \
        zlib1g-dev \
        libprotobuf-dev \
        protobuf-compiler \
        libprotoc-dev \
        libpng-dev \
        libhdf5-dev \
        libgoogle-perftools-dev \
        libboost-all-dev \
        gcc-arm-linux-gnueabihf \
        binutils-gold && \
    rm -rf /var/lib/apt/lists/*

    # Upgrade pip and install Python packages (including Jupyter)
    python3 -m pip install --upgrade pip setuptools wheel
    
    # Install Python dependencies for gem5, analysis, and Jupyter
    pip3 install --no-cache-dir \
        scons \
        numpy \
        matplotlib \
        pandas \
        scipy \
        jupyter \
        jupyterlab \
        ipykernel

%labels
    Author "LMUL Hardware Acceleration Project"
    Version "1.0"
    Description "Container for gem5 simulator with LMUL accelerator model"

%help
    This container includes all dependencies needed to build and run gem5
    with the LMUL (logarithmic multiplication) accelerator model.
    
    To build gem5:
    1. Clone gem5: git clone https://github.com/gem5/gem5.git
    2. Run install script: ./gem5-sim/scripts/install_model.sh
    
    To run simulations:
    ./gem5-sim/scripts/run_simulation.sh
