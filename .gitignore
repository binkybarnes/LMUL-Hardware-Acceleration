# Build artifacts
obj_dir/
sim_build/
*.vcd
*.fst
*.out

# Compiled binaries (architecture-specific)
*.arm
*.x86
*.o

# Simulation files
sim_work/
*.xml
results.xml

# Python
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# GitHub workflows (if you want to ignore)
.github/

# IDE
.vscode/
.idea/

# System files
.DS_Store
*.swp
*~

# Report metadata
report/report.aux
report/report.bbl
report/report.fdb_latexmk
report/report.fls
report/report.log
report/report.synctex.gz
report/report.thm
report/report.toc

# Synthesis library files (downloaded during Docker build)
lib/*.lib
!lib/NangateOpenCellLibrary_typical.lib

# Synthesis output files (can be regenerated)
synthesis/out/*
!synthesis/out/.gitkeep
!synthesis/out/README.md
!synthesis/out/netlists/
!synthesis/out/netlists/*.v
!synthesis/out/logs/
!synthesis/out/logs/*.log
!synthesis/out/reports/
!synthesis/out/reports/verified_results.json

# Documentation files (ignore .md files except README.md)
*.md
!README.md
!**/README.md

# gem5 repository (large, should be cloned separately)
gem5/
!gem5/.gitignore

# Local-only cluster scripts (keep locally, do not commit)
gem5-sim/scripts/sbatch_compare_lmul_vs_ieee.slurm